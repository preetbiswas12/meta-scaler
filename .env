# Required Environment Variables for EmailTriageEnv OpenEnv Submission
# These MUST be set for mandatory requirements compliance

# API Configuration (REQUIRED)
API_BASE_URL="https://api.openai.com/v1"
MODEL_NAME="gpt-3.5-turbo"

# API Key (REQUIRED - set ONE of these)
# Option 1: OpenAI API Key
OPENAI_API_KEY="sk-your-actual-openai-key-here"

# Option 2: OpenRouter / Hugging Face Token
# HF_TOKEN="sk-or-v1-your-actual-openrouter-key-here"

# Python Settings
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
