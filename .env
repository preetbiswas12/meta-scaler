# Required Environment Variables for EmailTriageEnv OpenEnv Submission
# IMPORTANT: Validator will inject API_BASE_URL and API_KEY at runtime
# DO NOT HARDCODE API KEYS - use environment variables only

# API Configuration
# These are provided by the validator at runtime
API_BASE_URL="https://api.openai.com/v1"
MODEL_NAME="gpt-3.5-turbo"

# API Key Sources (in priority order):
# 1. API_KEY - Injected by validator (LiteLLM proxy)
# 2. OPENAI_API_KEY - OpenAI direct (fallback for local dev)
# 3. HF_TOKEN - Hugging Face token (fallback for local dev)
# 
# IMPORTANT: The validator injects API_KEY and API_BASE_URL.
# The OpenAIClient will use them automatically.
# DO NOT hardcode credentials in this file for production!

# Python Settings
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
